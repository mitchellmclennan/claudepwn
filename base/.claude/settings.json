{
  "permissions": {
    "allow": [
      "Bash(*)",
      "Read(**)",
      "Write(**)",
      "Edit(**)",
      "MultiEdit(**)",
      "Glob(**)",
      "Grep(**)",
      "TodoWrite",
      "TodoRead",
      "WebSearch",
      "WebFetch(*)"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(rm -rf .git)",
      "Bash(curl * | bash)",
      "Bash(wget * | bash)",
      "Bash(drop database*)",
      "Bash(DROP TABLE*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/pre-edit.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/post-edit.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/post-bash.sh"
          }
        ]
      }
    ]
  },
  "plugins": [
    "security-guidance@anthropics-claude-code",
    "code-review@anthropics-claude-code",
    "frontend-design@anthropics-claude-code",
    "claude-mem@thedotmack"
  ]
}
